{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*:80/post" },
        { "url": "https://app.divoom-gz.com/*" }
      ]
    },
    "store:default"
  ]
}
